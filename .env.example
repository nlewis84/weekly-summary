# For commits_pushed: org and comma-separated repos (default: ApollosProject + apollos-admin,apollos-cluster,apollos-platforms,git-for-sql)
# GITHUB_ORG=ApollosProject
# GITHUB_COMMIT_REPOS=apollos-admin,apollos-cluster,apollos-platforms,git-for-sql
# Comma-separated paths for weekly summaries (e.g. 2025-weekly-work-summaries,2026-weekly-work-summaries)
# GITHUB_SUMMARY_PATHS=2026-weekly-work-summaries
CURSOR_API_KEY=sk-xxxxx

# Basecamp integration (optional — enables "Post to Basecamp" checkbox)
# Requires: basecamp CLI installed and authenticated (https://basecamp.com/agents#cli)
# BASECAMP_PROJECT_ID=
# BASECAMP_CHECKIN_QUESTION_ID=
# Optional: post weekly summary as a check-in answer instead of a message
# BASECAMP_WEEKLY_QUESTION_ID=
